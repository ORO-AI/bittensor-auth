# bittensor-auth CLI demo
# Record with: cd ~/oro/bittensor-auth && VHS_CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" vhs examples/demo.tape

Output examples/demo.gif

Set Shell "bash"
Set FontSize 13
Set Width 960
Set Height 640
Set Padding 16
Set Theme "Catppuccin Mocha"
Set TypingSpeed 30ms

Type "uv run python demo.py"
Enter
Sleep 35s
